#!/usr/bin/env bash
#MISE description="Remove stale symlinks left behind when config/dotfile entries are removed"
#MISE raw=true
#USAGE flag "--yes" help="Delete without confirming"
#USAGE flag "--dry-run" help="Only report what would be removed"
set -euo pipefail

# mise keeps no state database: removing a [dotfiles] entry (or renaming a
# config.<profile>.toml) leaves its symlink in place, pointing at a source that
# no longer exists. Nothing reports this — `mise config ls`, `dotfiles status`
# and `doctor` all stay quiet while the profile's settings silently stop
# applying. This task is the missing reaper.
#
# It only ever removes symlinks that (a) are dangling and (b) point into this
# repo. Real files, and links to anything else, are never touched.

REPO="${DOTFILES_MISE_REPO:-$HOME/.dotfiles-mise}"
CONF="${MISE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/mise}"

DRY_RUN="${usage_dry_run:-false}"
ASSUME_YES="${usage_yes:-false}"

info() { printf '\033[1;34m[INFO]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$*"; }
ok() { printf '\033[1;32m[ OK ]\033[0m %s\n' "$*"; }

# A missing or half-checked-out repo makes EVERY deployed link dangle, which
# would turn this task into "delete all my dotfiles". Refuse in that case: the
# fix there is to restore the repo, not to reap the links.
#
# The guard has to cover EVERY root whose links we are willing to delete, not
# just $REPO. It used to validate $REPO while the ownership patterns also
# accepted a hardcoded "$HOME/.dotfiles-mise/..." — so pointing
# $DOTFILES_MISE_REPO at any complete checkout (a git worktree, a CI workspace;
# .github/workflows/ci.yml sets that variable) while ~/.dotfiles-mise was
# missing passed the guard and classified every deployed dotfile as stale.
# Reproduced in a fake $HOME: ~/.zshrc was listed for removal.
ROOTS=()
for candidate in "$REPO" "$HOME/.dotfiles-mise"; do
    [[ -d "$candidate/home" && -d "$candidate/mise" ]] || continue
    # De-duplicate: the two are the same path in the normal case.
    for existing in ${ROOTS[@]+"${ROOTS[@]}"}; do
        [[ "$existing" == "$candidate" ]] && continue 2
    done
    ROOTS+=("$candidate")
done

if ((${#ROOTS[@]} == 0)); then
    warn "$REPO looks incomplete (missing home/ or mise/) — refusing to remove anything."
    warn "Restore the repo first; every link would look stale right now."
    exit 1
fi

# A link is ours only if it points into a root we just verified is complete.
owned() { # <link target> [subdir under the root]
    local target="$1" sub="${2:-}" r
    for r in "${ROOTS[@]}"; do
        [[ "$target" == "$r$sub"/* ]] && return 0
    done
    return 1
}

stale=()

# 1. mise's own config links (~/.config/mise/config*.toml, tasks)
shopt -s nullglob
for link in "$CONF"/config*.toml "$CONF/tasks"; do
    [[ -L "$link" ]] || continue
    target="$(readlink "$link")"
    owned "$target" || continue
    [[ -e "$link" ]] || stale+=("$link")
done

# 1b. conf.d drop-ins — in practice the companion repo's 50-custom.toml, which
#     setup:custom-hookup symlinks out of a clone the user may later delete. A
#     dangling drop-in is harmless to mise (it simply omits the file), but it
#     is exactly the invisible leftover this task exists for — and while it
#     sits there `setup:custom-hookup` reports "already linked" and does
#     nothing. These point OUTSIDE this repo, so ownership cannot be "points
#     into $REPO".
#
#     But it must still be *some* ownership test. Reaping every dangling
#     conf.d link deleted drop-ins this repo never created — one pointing at an
#     unmounted volume, or at a companion clone that is merely not cloned yet,
#     is a link the user wants back, not a leftover. Only the drop-in we
#     create, and links into the companion directory, are ours; anything else
#     is reported and left alone.
CUSTOM_DIR="${DOTFILES_CUSTOM_MISE_DIR:-$HOME/.dotfiles-custom-mise}"
for link in "$CONF"/conf.d/*; do
    [[ -L "$link" && ! -e "$link" ]] || continue
    target="$(readlink "$link")"
    if [[ "$(basename "$link")" == "50-custom.toml" || "$target" == "$CUSTOM_DIR"/* ]]; then
        stale+=("$link")
    else
        warn "Dangling conf.d drop-in not created by this repo, leaving it: $link -> $target"
    fi
done

# 2. Deployed dotfiles. Scan ~ shallowly plus the XDG trees, where nested
#    targets live (a flat -maxdepth would miss ~/.config/a/b/c).
while IFS= read -r -d '' link; do
    target="$(readlink "$link")"
    owned "$target" "/home" || continue
    [[ -e "$link" ]] || stale+=("$link")
done < <(
    find "$HOME" -maxdepth 1 -type l -print0 2>/dev/null
    # ~/.claude and ~/.gnupg hold managed links too (per-file, D8). ~/.claude
    # matters most: commands/ is symlink-each, the mode where a per-file link is
    # left dangling the moment a source file is deleted from the repo.
    # ~/.themes holds the gnome profile's whole-dir theme links — the clearest
    # case of the removal problem this task exists for: drop the profile and
    # the links stay, pointing at a config file mise no longer loads.
    for d in "$HOME/.config" "$HOME/.local/share" "$HOME/.local/bin" "$HOME/.claude" "$HOME/.gnupg" "$HOME/.themes"; do
        # -path prune: ~/.local/share/mise is mise's whole tool tree (tens of
        # thousands of files, none of them ours) and ~/.claude/projects is
        # session history.
        [[ -d "$d" ]] && find "$d" \
            \( -path "$HOME/.local/share/mise" -o -path "$HOME/.claude/projects" \) -prune \
            -o -type l -print0 2>/dev/null
    done
)
shopt -u nullglob

if [[ ${#stale[@]} -eq 0 ]]; then
    ok "No stale symlinks pointing into $REPO"
    exit 0
fi

warn "Stale symlinks (source no longer exists in the repo):"
for s in "${stale[@]}"; do
    printf '    %s -> %s\n' "$s" "$(readlink "$s")"
done

if [[ "$DRY_RUN" == "true" ]]; then
    info "--dry-run: nothing removed"
    exit 0
fi

if [[ "$ASSUME_YES" != "true" ]]; then
    read -rp "Remove these ${#stale[@]} symlink(s)? [y/N] " a || a=n
    [[ "$a" =~ ^[Yy]$ ]] || {
        info "Aborted"
        exit 0
    }
fi

for s in "${stale[@]}"; do
    rm "$s"
    ok "Removed $s"
done
