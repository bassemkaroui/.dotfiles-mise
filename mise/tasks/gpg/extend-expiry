#!/usr/bin/env bash
#MISE description="Extend GPG key expiration non-interactively (primary + all subkeys)"
#MISE raw=true
#USAGE flag "--period <period>" help="Extension period: Nd/Nw/Nm/Ny, ISO date (YYYY-MM-DD), or 0 for never" default="1y"
#USAGE flag "--key <fpr>" help="Fingerprint (or suffix) of the primary key to extend; skips the picker"
#USAGE flag "--yes" help="Apply without confirming"
set -eo pipefail

# shellcheck disable=SC2034  # consumed by the logging helpers in lib/profile.sh
TASK_NAME="gpg:extend-expiry"
LIB="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib"
# shellcheck source=../lib/profile.sh
source "$LIB/profile.sh"
# shellcheck source=../lib/gpg.sh
source "$LIB/gpg.sh"

require_gpg

PERIOD="${usage_period:-1y}"
WANT_KEY="${usage_key:-}"
# shellcheck disable=SC2034  # read by confirm() in lib/gpg.sh, which is sourced above
ASSUME_YES="${usage_yes:-false}"

# Best-effort human preview of where the new expiry will land.
# Returns "never" for 0, "YYYY-MM-DD" when we can compute it, "(computed by gpg)" otherwise.
preview_new_expiry() {
    local p="$1"
    if [[ "$p" == "0" ]]; then
        printf 'never'
        return
    fi
    if [[ "$p" =~ ^([0-9]+)([dwmy])$ ]]; then
        local n="${BASH_REMATCH[1]}" unit="${BASH_REMATCH[2]}"
        local word
        case "$unit" in
            d) word=day ;;
            w) word=week ;;
            m) word=month ;;
            y) word=year ;;
        esac
        date -u -d "now + $n $word" +%Y-%m-%d 2>/dev/null && return
    fi
    if [[ "$p" =~ ^[0-9]{4}-[0-9]{2}-[0-9]{2}$ ]]; then
        printf '%s' "$p"
        return
    fi
    printf '(computed by gpg)'
}

mapfile -t primaries < <(primary_fprs)
((${#primaries[@]} > 0)) || {
    warn "No secret keys found in keyring"
    exit 0
}

# --key selects without the picker, so this task can run from a cron reminder
# or a script on a machine with several keys.
if [[ -n "$WANT_KEY" ]]; then
    matches=()
    for fpr in "${primaries[@]}"; do
        [[ "$fpr" == *"${WANT_KEY^^}" ]] && matches+=("$fpr")
    done
    case "${#matches[@]}" in
        1) selected="${matches[0]}" ;;
        0) fail "No secret key matches --key $WANT_KEY" ;;
        *) fail "--key $WANT_KEY matches ${#matches[@]} keys — pass more of the fingerprint" ;;
    esac
    info "Selected key: $(short_fpr "$selected")"
elif ((${#primaries[@]} == 1)); then
    selected="${primaries[0]}"
    info "Using only secret key: $(short_fpr "$selected")"
else
    # The picker needs a terminal. A chained/unattended caller must use --key.
    [[ -t 0 ]] || fail "${#primaries[@]} secret keys present and no terminal to choose at — pass --key <fpr>"
    info "Multiple secret keys — choose one to extend:"
    for i in "${!primaries[@]}"; do
        fpr="${primaries[$i]}"
        uid="$(gpg --list-keys --with-colons --fixed-list-mode "$fpr" 2>/dev/null \
            | awk -F: '$1 == "uid" { print $10; exit }')"
        printf '  [%d] %s  %s\n' "$((i + 1))" "$(short_fpr "$fpr")" "$uid"
    done
    printf 'Select number: '
    read -r choice
    if ! [[ "$choice" =~ ^[0-9]+$ ]] || ((choice < 1 || choice > ${#primaries[@]})); then
        fail "Invalid selection: $choice"
    fi
    selected="${primaries[$((choice - 1))]}"
fi

echo
info "Current expiry for $(short_fpr "$selected"):"
print_expiry_header 0
while IFS= read -r row; do
    print_expiry_row "$row" 0
done < <(secret_keys_stream | awk -F"$GPG_FS" -v fpr="$selected" '$2 == fpr')

echo
projected="$(preview_new_expiry "$PERIOD")"
info "Will extend primary + all subkeys by: $PERIOD  (→ $projected)"

confirm "Apply?" || {
    warn "Aborted — no changes made"
    exit 0
}

gpg --quiet --quick-set-expire "$selected" "$PERIOD" >/dev/null
ok_changed "Extended primary key $(short_fpr "$selected") by $PERIOD"

gpg --quiet --quick-set-expire "$selected" "$PERIOD" '*' >/dev/null
ok_changed "Extended all subkeys of $(short_fpr "$selected") by $PERIOD"

echo
info "New expiry:"
print_expiry_header 0
while IFS= read -r row; do
    print_expiry_row "$row" 0
done < <(secret_keys_stream | awk -F"$GPG_FS" -v fpr="$selected" '$2 == fpr')
