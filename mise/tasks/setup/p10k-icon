#!/usr/bin/env bash
#MISE description="Set the powerlevel10k OS icon (writes ~/.p10k.local.zsh)"
#MISE raw=true
#USAGE flag "--icon <icon>" help="Set this icon without prompting"
#USAGE flag "--show" help="Print the icon currently configured"
#USAGE flag "--clear" help="Remove the override and fall back to ~/.p10k.zsh"
set -eo pipefail

# shellcheck disable=SC2034  # consumed by the logging helpers in lib/profile.sh
TASK_NAME="setup:p10k-icon"
# shellcheck source=../lib/profile.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/profile.sh"

# ─── The escapes below need a UTF-8 locale ────────────────────────────────────
# bash expands $'\uXXXX' AT PARSE TIME against the CURRENT locale, and when the
# codepoint cannot be represented it leaves the escape as LITERAL TEXT. In
# C/POSIX — no LANG, which is normal for a container, a cron job, a minimal
# server image or `env -i` — every icon below therefore becomes the 6-character
# string \uF32A, and this task cheerfully writes
#   typeset -g POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION='uF32A'
# into ~/.p10k.local.zsh (awk -v eats the backslash on the way). The prompt
# then shows that text forever. Reproduced with `env -i`.
#
# The probe compares against the escape SPELLED OUT in single quotes; there is
# deliberately no literal Private Use Area glyph anywhere in this file, because
# any encoding-unaware tool in the editing chain silently eats those.
_probe=$'\uF32A'
if [[ "$_probe" == '\uF32A' ]]; then
    if [[ -z "${P10K_ICON_UTF8_REEXEC:-}" ]]; then
        # Re-exec once in a UTF-8 locale. The sentinel prevents a loop if the
        # chosen locale is not actually available.
        for _loc in C.UTF-8 en_US.UTF-8; do
            if LC_ALL="$_loc" locale charmap 2>/dev/null | grep -qi 'utf-*8'; then
                export P10K_ICON_UTF8_REEXEC=1
                exec env LC_ALL="$_loc" bash "${BASH_SOURCE[0]}" "$@"
            fi
        done
    fi
    # Verified, not trusted: if it is still degraded, write nothing rather than
    # putting the escape text in the user's prompt.
    warn "This locale (${LC_ALL:-${LANG:-C}}) cannot represent the Nerd Font glyphs;"
    warn "writing an icon now would put the text 'uF32A' in your prompt."
    skip "Install a UTF-8 locale (e.g. locale-gen C.UTF-8) and re-run: mise run setup:p10k-icon"
fi
unset _probe

# Port of the old repo's setup:p10k-icon, and the reason the companion repo no
# longer needs a p10k package at all: its tag-desktop/.p10k.zsh differed from
# the shared one by exactly ONE line — this icon. A 1700-line copy declared in
# two repos (undefined precedence, §2.2) is replaced by one line in a
# machine-local file.
#
# ~/.zshrc sources ~/.p10k.local.zsh *after* ~/.p10k.zsh, so an override here
# wins and survives `p10k configure` regenerating the main file.
#
# In the bootstrap chain this asks AT MOST ONCE per machine: only when stdin is
# a terminal and the file carries no answer yet. The old task asked on every
# single bootstrap, which is the part that made it annoying rather than useful.

LOCAL="$HOME/.p10k.local.zsh"
KEY="POWERLEVEL9K_OS_ICON_CONTENT_EXPANSION"
MARKER="# p10k-icon: asked" # presence = "already offered on this machine"
URL="https://www.nerdfonts.com/cheat-sheet"

# Verified present in the FiraCode Nerd Font that setup:fonts installs (the
# cmap of the shipped .ttf was checked for each codepoint). Written as \u
# escapes rather than literal glyphs: these are Private Use Area characters
# that any encoding-unaware tool in the chain will silently eat — one already
# did while this file was being written. The escape also tells a reader which
# codepoint to look up on the cheat sheet.
CHOICES=(
    $'\U000F048D|the one this setup used before (nf-md-lan_connect)'
    $'\uF32A|Pop!_OS'
    $'\uF31B|Ubuntu'
    $'\uF306|Debian'
    $'\uF303|Arch'
    $'\uF30A|Fedora'
    $'\uF17C|Linux (Tux)'
    $'\uF31C|Linux Mint'
)

current_icon() {
    [[ -f "$LOCAL" ]] || return 0
    sed -n "s/^[[:space:]]*typeset -g ${KEY}='\(.*\)'$/\1/p" "$LOCAL" | tail -1
}

# Replace the line if present, append it otherwise — never duplicate it.
write_icon() {
    local icon="$1" tmp
    # Unconditionally, in BOTH branches: the replace branch below skipped it,
    # so setting an icon on a machine whose file already had the typeset line
    # left no record that the question had been answered.
    ensure_file
    if [[ -f "$LOCAL" ]] && grep -q "^[[:space:]]*typeset -g ${KEY}=" "$LOCAL"; then
        tmp="$(mktemp)"
        awk -v repl="typeset -g ${KEY}='${icon}'" -v key="${KEY}" '
            $0 ~ "^[[:space:]]*typeset -g " key "=" { print repl; next }
            { print }
        ' "$LOCAL" >"$tmp" && mv -f "$tmp" "$LOCAL"
    else
        printf "typeset -g %s='%s'\n" "$KEY" "$icon" >>"$LOCAL"
    fi
}

# Create the file if missing, and make sure it carries $MARKER either way.
#
# It used to return early on an existing file, so the marker was only ever
# written on a machine that had none — while write_icon's replace branch never
# called this at all. Any machine migrating from the OLD repo has a
# ~/.p10k.local.zsh already (the old task wrote the same header without a
# marker), so those machines never recorded an answer and this task re-printed
# its menu on EVERY bootstrap from a terminal, including right after the user
# picked "Keep the default (and stop asking)". That is the exact annoyance the
# header comment above claims to have fixed.
ensure_file() {
    if [[ ! -f "$LOCAL" ]]; then
        cat >"$LOCAL" <<EOF
# Per-machine powerlevel10k overrides. Sourced by ~/.zshrc AFTER ~/.p10k.zsh,
# so anything set here wins and survives \`p10k configure\`. Machine-local on
# purpose: not in any repo, not deployed by mise.
$MARKER
EOF
        return 0
    fi
    # Never rewrite the file to add the marker: append, so a symlinked or
    # user-edited file keeps its identity and contents.
    grep -qF "$MARKER" "$LOCAL" || printf '%s\n' "$MARKER" >>"$LOCAL"
}

# ─── --show / --clear ─────────────────────────────────────────────────────────

if [[ "${usage_show:-false}" == "true" ]]; then
    icon="$(current_icon)"
    if [[ -n "$icon" ]]; then
        info "OS icon: $icon  (from $LOCAL)"
    else
        info "No OS icon override on this machine — ~/.p10k.zsh decides"
    fi
    exit 0
fi

if [[ "${usage_clear:-false}" == "true" ]]; then
    if [[ -f "$LOCAL" ]] && grep -q "^[[:space:]]*typeset -g ${KEY}=" "$LOCAL"; then
        tmp="$(mktemp)"
        grep -v "^[[:space:]]*typeset -g ${KEY}=" "$LOCAL" >"$tmp" && mv -f "$tmp" "$LOCAL"
        # The marker deliberately stays: it is what stops the bootstrap chain
        # from asking again on the next run.
        ok_changed "Override removed — ~/.p10k.zsh decides again (run: exec zsh)"
    else
        ok "No override to remove"
    fi
    exit 0
fi

# ─── --icon (scriptable, no prompt) ───────────────────────────────────────────

if [[ -n "${usage_icon:-}" ]]; then
    write_icon "$usage_icon"
    ok_changed "OS icon set to: $usage_icon"
    info "Run 'exec zsh' to see it (tofu means your terminal font lacks the glyph)"
    exit 0
fi

# ─── Interactive ──────────────────────────────────────────────────────────────

# In the chain: no terminal (unattended run) or already answered → say nothing.
if [[ ! -t 0 ]]; then
    info "Not a terminal — run 'mise run setup:p10k-icon' to choose an icon"
    exit 0
fi
if [[ -f "$LOCAL" ]] && grep -qF "$MARKER" "$LOCAL"; then
    icon="$(current_icon)"
    [[ -n "$icon" ]] && ok "OS icon already set: $icon" || ok "OS icon left at the default"
    info "Change it any time: mise run setup:p10k-icon --icon '<glyph>'"
    exit 0
fi

printf '\n  powerlevel10k OS icon — the first segment of your prompt:\n\n'
for i in "${!CHOICES[@]}"; do
    printf '    %d) %s   %s\n' "$((i + 1))" "${CHOICES[$i]%%|*}" "${CHOICES[$i]#*|}"
done
CUSTOM_NUM=$((${#CHOICES[@]} + 1))
KEEP_NUM=$((CUSTOM_NUM + 1))
printf '    %d) Paste your own — browse at %s\n' "$CUSTOM_NUM" "$URL"
printf '    %d) Keep the default (and stop asking)\n\n' "$KEEP_NUM"
printf '  Choose [1-%d]: ' "$KEEP_NUM"
read -r CHOICE

if [[ -z "$CHOICE" || ! "$CHOICE" =~ ^[0-9]+$ ]] || ((CHOICE < 1 || CHOICE > KEEP_NUM)); then
    warn "Not a valid choice — leaving the icon alone (nothing written)"
    exit 0
fi

if ((CHOICE == KEEP_NUM)); then
    ensure_file
    ok "Keeping the default icon — this won't ask again"
    info "Change your mind any time: mise run setup:p10k-icon"
    exit 0
fi

if ((CHOICE == CUSTOM_NUM)); then
    printf '  Browse %s, then paste the glyph here: ' "$URL"
    read -r ICON
    [[ -n "$ICON" ]] || {
        warn "Nothing pasted — leaving the icon alone"
        exit 0
    }
else
    ICON="${CHOICES[$((CHOICE - 1))]%%|*}"
fi

write_icon "$ICON"
ok_changed "OS icon set to: $ICON"
info "Run 'exec zsh' to see it (tofu means your terminal font lacks the glyph)"
