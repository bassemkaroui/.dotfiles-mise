#!/usr/bin/env bash
#MISE description="Remove stale symlinks left behind when config/dotfile entries are removed"
#MISE raw=true
#USAGE flag "--yes" help="Delete without confirming"
#USAGE flag "--dry-run" help="Only report what would be removed"
set -euo pipefail

# mise keeps no state database: removing a [dotfiles] entry (or renaming a
# config.<profile>.toml) leaves its symlink in place, pointing at a source that
# no longer exists. Nothing reports this — `mise config ls`, `dotfiles status`
# and `doctor` all stay quiet while the profile's settings silently stop
# applying. This task is the missing reaper.
#
# It only ever removes symlinks that (a) are dangling and (b) point into this
# repo. Real files, and links to anything else, are never touched.

REPO="${DOTFILES_MISE_REPO:-$HOME/.dotfiles-mise}"
CONF="${MISE_CONFIG_DIR:-${XDG_CONFIG_HOME:-$HOME/.config}/mise}"

DRY_RUN="${usage_dry_run:-false}"
ASSUME_YES="${usage_yes:-false}"

info() { printf '\033[1;34m[INFO]\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m[WARN]\033[0m %s\n' "$*"; }
ok() { printf '\033[1;32m[ OK ]\033[0m %s\n' "$*"; }

# A missing or half-checked-out repo makes EVERY deployed link dangle, which
# would turn this task into "delete all my dotfiles". Refuse in that case: the
# fix there is to restore the repo, not to reap the links.
if [[ ! -d "$REPO/home" || ! -d "$REPO/mise" ]]; then
    warn "$REPO looks incomplete (missing home/ or mise/) — refusing to remove anything."
    warn "Restore the repo first; every link would look stale right now."
    exit 1
fi

stale=()

# 1. mise's own config links (~/.config/mise/config*.toml, tasks)
shopt -s nullglob
for link in "$CONF"/config*.toml "$CONF/tasks"; do
    [[ -L "$link" ]] || continue
    target="$(readlink "$link")"
    case "$target" in
        "$REPO"/* | "$HOME"/.dotfiles-mise/*) ;;
        *) continue ;;
    esac
    [[ -e "$link" ]] || stale+=("$link")
done

# 2. Deployed dotfiles. Scan ~ shallowly plus the XDG trees, where nested
#    targets live (a flat -maxdepth would miss ~/.config/a/b/c).
while IFS= read -r -d '' link; do
    target="$(readlink "$link")"
    case "$target" in
        "$REPO"/home/* | "$HOME"/.dotfiles-mise/home/*) ;;
        *) continue ;;
    esac
    [[ -e "$link" ]] || stale+=("$link")
done < <(
    find "$HOME" -maxdepth 1 -type l -print0 2>/dev/null
    # ~/.claude and ~/.gnupg hold managed links too (per-file, D8). ~/.claude
    # matters most: commands/ is symlink-each, the mode where a per-file link is
    # left dangling the moment a source file is deleted from the repo.
    for d in "$HOME/.config" "$HOME/.local/share" "$HOME/.local/bin" "$HOME/.claude" "$HOME/.gnupg"; do
        # -path prune: ~/.local/share/mise is mise's whole tool tree (tens of
        # thousands of files, none of them ours) and ~/.claude/projects is
        # session history.
        [[ -d "$d" ]] && find "$d" \
            \( -path "$HOME/.local/share/mise" -o -path "$HOME/.claude/projects" \) -prune \
            -o -type l -print0 2>/dev/null
    done
)
shopt -u nullglob

if [[ ${#stale[@]} -eq 0 ]]; then
    ok "No stale symlinks pointing into $REPO"
    exit 0
fi

warn "Stale symlinks (source no longer exists in the repo):"
for s in "${stale[@]}"; do
    printf '    %s -> %s\n' "$s" "$(readlink "$s")"
done

if [[ "$DRY_RUN" == "true" ]]; then
    info "--dry-run: nothing removed"
    exit 0
fi

if [[ "$ASSUME_YES" != "true" ]]; then
    read -rp "Remove these ${#stale[@]} symlink(s)? [y/N] " a || a=n
    [[ "$a" =~ ^[Yy]$ ]] || {
        info "Aborted"
        exit 0
    }
fi

for s in "${stale[@]}"; do
    rm "$s"
    ok "Removed $s"
done
