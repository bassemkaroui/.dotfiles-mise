#!/usr/bin/env bash
#MISE description="Wire up the private companion repo (per-user config that must stay out of this one)"
#MISE raw=true
set -eo pipefail

# shellcheck disable=SC2034  # consumed by the logging helpers in lib/profile.sh
TASK_NAME="setup:custom-hookup"
# shellcheck source=../lib/profile.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/profile.sh"

# D12 / §7.7. Some configuration must not live in this repo: git identity, ssh
# host names and ports, the GNOME extension manifest. In the old repo that was
# ~/.dotfiles-custom + `setup:custom-dotfiles` (stow packages, tag-* dirs and an
# INI tracker). The v2 companion is DATA, not a program — no installer, no
# tasks, no bootstrap logic:
#
#   ~/.dotfiles-custom-mise/
#   ├── mise/config.custom.toml   [dotfiles] entries, explicit absolute sources
#   ├── home/                     the private files those entries point at
#   └── templates/                *.tmpl for template-mode entries
#
# All this task does is symlink that one config file into
# ~/.config/mise/conf.d/50-custom.toml — where mise loads it alongside the main
# config once trusted — and apply it. The contract the companion must honour is
# in CUSTOM.md.
#
# install.sh creates the same link earlier, before its guard/backup/lint block,
# for machines where the clone already exists. This task is the other entry
# path: the fresh machine, where the companion is cloned right here, at
# bootstrap step 12 — long after install.sh finished. That is why every safety
# check install.sh performs is repeated below: trust, live lint, backup.

CUSTOM_DIR="${DOTFILES_CUSTOM_MISE_DIR:-$HOME/.dotfiles-custom-mise}"
DROPIN="$CONF/conf.d/50-custom.toml"
SOURCE_CONF="$CUSTOM_DIR/mise/config.custom.toml"

# ─── Clone it, so a fresh machine needs no manual git clone ───────────────────
#
# Why this is NOT a [bootstrap.repos] entry, which would be the obvious home for
# it (all three verified 2026-07-21):
#
#   1. A repos clone that fails ABORTS the whole bootstrap — the imperative tail
#      never runs and install.sh dies with it. The companion is private, so the
#      clone fails on every machine without credentials: CI, a fresh box before
#      its keys exist, and anyone else using this repo. A task can decline.
#   2. `url = "{{ env.SOMETHING }}"` is NOT templated in [bootstrap.repos] — the
#      literal string is used — so the URL cannot be supplied per machine there.
#   3. The companion's own remote is `git@github:...`, an ssh alias defined in
#      ~/.ssh/config — which the companion itself deploys. Cloning it by that
#      URL on a fresh machine is circular; deriving from this repo's remote
#      gives a canonical `git@github.com:` URL that resolves without the alias.
#
# URL resolution: $DOTFILES_CUSTOM_MISE_URL wins; otherwise it is derived from
# this repo's own origin by naming convention, so nothing private is committed
# here and any user of this repo gets their own companion, not the author's.
custom_url() {
    if [[ -n "${DOTFILES_CUSTOM_MISE_URL:-}" ]]; then
        printf '%s' "$DOTFILES_CUSTOM_MISE_URL"
        return 0
    fi
    local origin
    origin="$(git -C "$REPO" remote get-url origin 2>/dev/null || true)"
    [[ -n "$origin" ]] || return 1
    # <anything>.dotfiles-mise[.git] → <anything>.dotfiles-custom-mise.git
    case "$origin" in
        *.dotfiles-mise.git) printf '%s' "${origin%.dotfiles-mise.git}.dotfiles-custom-mise.git" ;;
        *.dotfiles-mise) printf '%s' "${origin%.dotfiles-mise}.dotfiles-custom-mise.git" ;;
        *) return 1 ;;
    esac
}

if [[ ! -d "$CUSTOM_DIR" ]]; then
    if ! url="$(custom_url)"; then
        info "No companion repo at $CUSTOM_DIR, and no URL to try"
        info "(clone it there, or set \$DOTFILES_CUSTOM_MISE_URL, then: mise run setup:custom-hookup)"
        exit 0
    fi
    info "Cloning the companion repo: $url"
    # Clone to a temp path and move on success. A clone that dies mid-transfer
    # (auth failure, dropped network) leaves a NON-EMPTY directory, which the
    # `-d` test above would then read as "already cloned" forever — and hooking
    # up a half-clone means a config file whose sources are missing, which
    # aborts every dotfiles apply on the machine (§2.16).
    tmp_clone="$CUSTOM_DIR.cloning.$$"
    rm -rf "$tmp_clone"
    # GIT_TERMINAL_PROMPT=0: without credentials git would otherwise sit waiting
    # for a username that an unattended bootstrap will never type.
    if GIT_TERMINAL_PROMPT=0 git clone --quiet "$url" "$tmp_clone" 2>/dev/null; then
        mv "$tmp_clone" "$CUSTOM_DIR"
        ok_changed "Cloned $url → $CUSTOM_DIR"
    else
        # Entirely normal: no companion repo exists, or this machine has no
        # credentials for it yet. Never fatal.
        rm -rf "$tmp_clone"
        info "Could not clone $url — continuing without a companion repo"
        info "(set up your git credentials, then: mise run setup:custom-hookup)"
        exit 0
    fi
fi

# ─── Hook it up ───────────────────────────────────────────────────────────────

if [[ ! -f "$SOURCE_CONF" ]]; then
    warn "$CUSTOM_DIR has no mise/config.custom.toml — nothing to hook up"
    warn "(the companion repo is data + one config file; see CUSTOM.md)"
    exit 0
fi

mkdir -p "$CONF/conf.d"

if [[ -e "$DROPIN" && ! -L "$DROPIN" ]]; then
    warn "$DROPIN exists and is a real file, not our symlink — leaving it alone"
    warn "(move it aside if you meant the companion repo to own it)"
    exit 0
fi

current_target="$(readlink "$DROPIN" 2>/dev/null || true)"
FIRST_LINK=false
if [[ "$current_target" == "$SOURCE_CONF" ]]; then
    ok "Companion drop-in already linked: $DROPIN"
else
    ln -sfn "$SOURCE_CONF" "$DROPIN"
    FIRST_LINK=true
    ok_changed "Linked $DROPIN → $SOURCE_CONF"
fi

# An UNTRUSTED conf.d drop-in is SILENTLY IGNORED — verified 2026-07-21: with
# it in place, `mise dotfiles status` exits 0, mentions no trust problem, and
# the entries simply do not exist. (That is gentler than §2.10's behaviour for
# the global config, and far more dangerous here: the companion would appear to
# be wired up and deploy nothing, so setup:git-signing — the very next chain
# step — would find no ~/.gitconfig.local.example and no-op forever.)
# install.sh trusts every conf.d file in its own step 6; this task runs at
# bootstrap step 12, long after that loop, so it must do its own.
mise trust "$DROPIN" >/dev/null 2>&1 || warn "Could not \`mise trust\` $DROPIN"

# ─── Validate BEFORE applying ─────────────────────────────────────────────────
# The drop-in is now loadable by every mise command on this machine, and two of
# its possible defects are machine-wide rather than local: a key that collides
# with the main repo resolves by undefined precedence (§2.2), and an entry whose
# explicit source is missing aborts the ENTIRE apply — this repo's entries
# included (§2.16). `lint-config.py --live` checks both. If it fails, take the
# link back out: a companion repo must never be able to break the main one.
if have python3 && [[ -f "$REPO/scripts/lint-config.py" ]]; then
    lint_rc=0
    python3 "$REPO/scripts/lint-config.py" --live || lint_rc=$?
    case "$lint_rc" in
        0) ok "Companion config passed the live lint" ;;
        2) warn "Live lint unavailable on this python — proceeding unchecked" ;;
        *)
            rm -f "$DROPIN"
            warn "Companion config FAILED the live lint (see above) — link removed."
            warn "Nothing was applied; the rest of this machine is unaffected."
            warn "Fix $SOURCE_CONF, then: mise run setup:custom-hookup"
            exit 0
            ;;
    esac
fi

# ─── Back up anything it would overwrite, then apply ──────────────────────────
# install.sh's backup pass ran before this drop-in existed (it is created here,
# at bootstrap step 12, on a fresh machine), so it could not have seen these
# targets. It matters most for ~/.ssh/config: a template-mode entry overwrites
# a pre-existing real file SILENTLY — no error, no backup — where symlink mode
# refuses (§2.26, reproduced against a real ~/.ssh/config).
back_up() {
    local target="$1" expanded bak n=1
    expanded="${target/#\~/$HOME}"
    # Real files only. A symlink is never data to mise, and replacing one is
    # what an apply is for.
    [[ -e "$expanded" && ! -L "$expanded" ]] || return 0
    bak="$expanded.pre-mise.bak"
    while [[ -e "$bak" ]]; do bak="$expanded.pre-mise.bak$((n++))"; done
    warn "Backing up $target → $bak before applying the companion repo"
    mv "$expanded" "$bak" || warn "Could not move $expanded aside"
}

# On the run that FIRST links the drop-in, read the companion's targets
# straight out of its TOML rather than asking mise.
#
# Why not `mise dotfiles status` here: it proved unreliable at exactly this
# moment. In repeated sandbox runs of this task, the status call issued
# immediately after creating and trusting the drop-in sometimes did not list
# the new entries at all, while the `dotfiles apply` a few lines later applied
# them — so the backup silently did nothing and the template-mode ~/.ssh/config
# was destroyed (§2.26). Reading the file we just linked has no such race, and
# this is the one moment where being wrong costs a real file.
backup_declared_targets() {
    have python3 || return 0
    local targets
    targets="$(
        python3 - "$SOURCE_CONF" <<'PY'
import sys
try:
    import tomllib
except ModuleNotFoundError:
    try:
        import tomli as tomllib
    except ModuleNotFoundError:
        sys.exit(0)
try:
    with open(sys.argv[1], "rb") as f:
        data = tomllib.load(f)
except Exception:
    sys.exit(0)
for target in data.get("dotfiles", {}):
    print(target)
PY
    )" || return 0
    while IFS= read -r target; do
        [[ -n "$target" ]] && back_up "$target"
    done <<<"$targets"
}

# On later runs the targets are already deployed, so a blanket backup would
# archive the rendered file again on every bootstrap. Fall back to mise's own
# drift detection there.
backup_differing() {
    have python3 || return 0
    { mise dotfiles status --json 2>/dev/null || true; } \
        | python3 -c '
import json, sys
raw = sys.stdin.read().strip()
if not raw:
    sys.exit(0)
try:
    data = json.loads(raw)
except json.JSONDecodeError:
    sys.exit(0)
for f in data.get("files", []):
    if f.get("state") == "differs":
        print(f["target"])
' \
        | while IFS= read -r target; do
            back_up "$target"
        done
}

if [[ "$FIRST_LINK" == true ]]; then
    backup_declared_targets
else
    backup_differing
fi

# Apply now rather than leaving it for the next bootstrap: the very next chain
# step (setup:git-signing) reads ~/.gitconfig.local.example, which this repo
# deploys. Verified that a chained task can apply within the same bootstrap and
# the next step sees the result.
if mise dotfiles apply --yes >/dev/null 2>&1 || mise dotfiles apply >/dev/null 2>&1; then
    ok "Applied the companion repo's dotfiles"
else
    warn "\`mise dotfiles apply\` failed after linking the companion repo"
    warn "(run it by hand to see why: mise dotfiles status)"
fi

# Template mode gives the rendered file the SOURCE's permissions — and git does
# not carry them: it records only the executable bit, so a template committed
# as 0600 comes out of a fresh clone at 0664 (umask), and the rendered
# ~/.ssh/config with it. ssh then refuses the whole file ("Bad owner or
# permissions"), which is a broken-ssh-on-a-new-machine bug that no amount of
# chmod in the companion repo can prevent. Reproduced in a sandbox: 600 when
# applying from the author's working copy, 664 from a clone of it.
# So the guarantee has to be enforced here, on the deployed side.
if [[ -d "$HOME/.ssh" ]]; then
    chmod 700 "$HOME/.ssh"
    while IFS= read -r f; do
        [[ -f "$f" ]] || continue
        [[ "$(stat -c '%a' "$f" 2>/dev/null)" == "600" ]] && continue
        chmod 600 "$f"
        ok_changed "Tightened $(basename "$f") to 0600 (git cannot carry file modes)"
    done < <(find "$HOME/.ssh" -maxdepth 1 -type f 2>/dev/null)
fi
