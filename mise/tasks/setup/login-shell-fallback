#!/usr/bin/env bash
#MISE description="If the login shell still isn't zsh, exec into it from ~/.bash_profile"
#MISE raw=true
set -eo pipefail

# shellcheck disable=SC2034  # consumed by the logging helpers in lib/profile.sh
TASK_NAME="setup:login-shell-fallback"
# shellcheck source=../lib/profile.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../lib/profile.sh"

# [bootstrap.user].login_shell already tried the chsh/usermod route. It cannot
# work for NSS-managed accounts (Google Cloud OS Login, LDAP, SSSD): those users
# aren't in /etc/passwd at all, and chsh/usermod only edit /etc/passwd. It also
# fails on locked-down hosts where chsh PAM-prompts and nobody is watching.
# This is the old repo's Method 4 (setup:zsh Phase 2), kept as the last resort.
#
# Caveat inherited from the old repo: `exec zsh` only covers TTY/SSH logins.
# Graphical terminal emulators read the shell from /etc/passwd, so on a desktop
# with an NSS account the terminal profile still has to be pointed at zsh by
# hand.

if ! command -v zsh &>/dev/null; then
    warn "zsh not installed — skipping (apt:zsh is a core [bootstrap.packages] entry)"
    exit 0
fi
ZSH_PATH="$(command -v zsh)"

# $USER is unset under cron, `docker exec`, and some CI runners; getent with an
# empty argument would silently return the wrong thing.
USER="${USER:-$(id -un)}"
CURRENT_SHELL="$(getent passwd "$USER" 2>/dev/null | cut -d: -f7 || true)"
[[ -z "$CURRENT_SHELL" ]] && CURRENT_SHELL="${SHELL:-}"

if [[ "$CURRENT_SHELL" == *zsh* ]]; then
    ok "Login shell is already zsh ($CURRENT_SHELL)"
    exit 0
fi

# This task owns the login shell outright — there is no [bootstrap.user]
# section, because mise's version runs bare `chsh -s`, which PAM-prompts and so
# fails unattended, and a failing bootstrap step aborts every step after it
# (§2.27). That made this very task unreachable in the case it exists for.
#
# The old repo's four-rung cascade (setup/zsh:112-158), in the order that works:
# sudo chsh → sudo usermod (both unattended-safe) → plain chsh (needs a
# terminal; a chained task does have one, §2.22) → `exec zsh` in a login file.
# NSS-managed accounts skip the first three: they aren't in /etc/passwd, so
# chsh/usermod can only fail with "user does not exist".
NSS_ONLY=false
if ! grep -q "^${USER}:" /etc/passwd 2>/dev/null; then
    NSS_ONLY=true
    info "User '$USER' is NSS-managed (not in /etc/passwd) — chsh/usermod can't work here"
fi

if [[ "$NSS_ONLY" == false ]] && command -v sudo &>/dev/null; then
    # Non-interactive sudo only: a password prompt here would hang an
    # unattended bootstrap, which is the scenario this rung exists for.
    if sudo -n true 2>/dev/null; then
        if command -v chsh &>/dev/null && sudo -n chsh -s "$ZSH_PATH" "$USER" 2>/dev/null; then
            ok_changed "Login shell changed to $ZSH_PATH via sudo chsh"
            exit 0
        fi
        # No `command -v usermod` guard: it lives in /usr/sbin, which is
        # usually off a non-root PATH even though sudo can run it.
        if sudo -n usermod -s "$ZSH_PATH" "$USER" 2>/dev/null; then
            ok_changed "Login shell changed to $ZSH_PATH via sudo usermod"
            exit 0
        fi
    fi
fi

# Rung 3: plain chsh. It PAM-prompts, so it is only offered at a terminal —
# which a chained task does have when the user runs `mise bootstrap` from one.
if [[ "$NSS_ONLY" == false && -t 0 ]] && command -v chsh &>/dev/null; then
    info "Trying chsh (it will ask for your password; Ctrl-C to skip)"
    if chsh -s "$ZSH_PATH"; then
        ok_changed "Login shell changed to $ZSH_PATH via chsh"
        exit 0
    fi
    warn "chsh did not change the login shell — falling back to the login file"
fi

# ~/.bash_profile, not ~/.profile: bash prefers it, and ~/.profile is a managed
# [dotfiles] symlink — appending to it would write into the repo.
LOGIN_FILE="$HOME/.bash_profile"

if grep -q 'exec zsh -l' "$LOGIN_FILE" 2>/dev/null; then
    ok "exec zsh already in $LOGIN_FILE"
    exit 0
fi

# This has to come BEFORE the legacy-migration branch below, not after it.
# The guard used to sit further down, guarding only the append — while the
# migration branch did an in-place `sed -i` and an append of its own 29 lines
# earlier. GNU sed -i writes a new file and renames it over the path, so a
# symlinked ~/.bash_profile was silently REPLACED BY A REGULAR FILE, detaching
# it from whatever manages it while leaving the link target untouched.
# Reproduced with ~/.bash_profile symlinked to a repo file containing the old
# repo's exact output: mode went 0664 -> regular file, target unchanged.
if [[ -L "$LOGIN_FILE" ]]; then
    warn "$LOGIN_FILE is a symlink — refusing to edit it (that would rewrite, or detach, the link target)"
    warn "Add 'exec zsh' to your login file by hand, or point the account at $ZSH_PATH"
    exit 0
fi

# A machine that took this rung under the OLD repo (or under this task before
# the guard existed) has a bare `exec zsh` line. It does not match the check
# above, so appending would leave TWO blocks with the unguarded one first —
# reached first, so both defects below would survive on exactly the machines
# that already have the problem. Rewrite it in place instead.
if grep -qE '^[[:space:]]*exec zsh[[:space:]]*$' "$LOGIN_FILE" 2>/dev/null; then
    if sed -i -E 's|^[[:space:]]*exec zsh[[:space:]]*$|case $- in *i*) exec zsh -l ;; esac|' "$LOGIN_FILE"; then
        ok_changed "Rewrote the legacy unconditional \`exec zsh\` in $LOGIN_FILE"
        # ~/.profile: only source it if this file does not already, and only
        # when nothing else would have. Appending blindly risks double-sourcing.
        if ! grep -q '\.profile' "$LOGIN_FILE" 2>/dev/null && [[ -f "$HOME/.profile" ]]; then
            printf '\n# ~/.bash_profile shadows ~/.profile for login bash — read it.\n[ -f "$HOME/.profile" ] && . "$HOME/.profile"\n' >>"$LOGIN_FILE"
            ok_changed "Added the missing ~/.profile source to $LOGIN_FILE"
        fi
        exit 0
    fi
    warn "Could not rewrite the legacy \`exec zsh\` line in $LOGIN_FILE — edit it by hand"
    exit 0
fi
# The old repo's bare `exec zsh` (which this file shipped until now) had two
# defects, both inherited verbatim and both fixed below — CI asserts each:
#
#   1. It replaced the shell UNCONDITIONALLY, so `bash --login -c '<cmd>'`
#      exec'd into an interactive zsh and never ran <cmd>. Every provisioning
#      tool that shells in that way (ansible, `ssh host <cmd>`, docker exec
#      -l, cloud-init) silently stopped working. Guarded on $- now: only an
#      interactive login shell is replaced.
#   2. Creating ~/.bash_profile makes bash stop reading ~/.profile entirely
#      (it reads the first of .bash_profile/.bash_login/.profile that exists),
#      so a machine that took this rung lost the PATH exports in ~/.profile
#      for every non-interactive login shell. When we are the ones creating
#      the file, it sources ~/.profile first.
CREATED_LOGIN_FILE=false
[[ -e "$LOGIN_FILE" ]] || CREATED_LOGIN_FILE=true

{
    printf '\n# Added by mise run setup:login-shell-fallback — the account shell is\n'
    printf '# %s and could not be changed to zsh.\n' "${CURRENT_SHELL:-unknown}"
    if [[ "$CREATED_LOGIN_FILE" == true ]]; then
        printf '# This file did not exist before, and its mere existence stops bash from\n'
        printf '# reading ~/.profile, so read it here.\n'
        printf '[ -f "$HOME/.profile" ] && . "$HOME/.profile"\n'
    fi
    printf 'export SHELL=%s\n' "$ZSH_PATH"
    printf '# Interactive login shells only: `bash --login -c "<cmd>"` must still run\n'
    printf '# <cmd> instead of being replaced by an interactive zsh.\n'
    printf 'case $- in *i*) exec zsh -l ;; esac\n'
} >>"$LOGIN_FILE"
ok_changed "Added 'exec zsh' to $LOGIN_FILE (login shell was ${CURRENT_SHELL:-unknown})"
